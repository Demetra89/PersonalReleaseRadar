    {
      "parameters": {
        "method": "POST",
        "url": "=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent?key={{ $env.GEMINI_API_KEY }}",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"contents\": [\n    {\n      \"parts\": [\n        {\n          \"text\": \"Ты — классификатор музыкальных новостей. Тебе присылают текст поста из телеграм-канала о музыке. Определи, анонсирует ли пост НОВЫЙ релиз (сингл, альбом, снипет с датой выхода, дроп) конкретного артиста, или нет (мемы, драма между артистами, тур-новости, реклама, просто фото/цитата без релиза).\\n\\nВерни строго JSON без markdown-обёртки и пояснений:\\n{\\n  \\\"is_release\\\": true/false,\\n  \\\"artist\\\": \\\"имя артиста или null\\\",\\n  \\\"title\\\": \\\"название трека/альбома или null\\\",\\n  \\\"release_type\\\": \\\"single/album/snippet/unknown\\\",\\n  \\\"confidence\\\": 0.0-1.0\\n}\\n\\nЕсли не уверен — ставь is_release: false.\\n\\nТекст поста:\\n\" + JSON.stringify($json.contentSnippet || $json.title)\n        }\n      ]\n    }\n  ]\n}",
        "options": {}
      },
      "id": "11",
      "name": "Gemini Classifier (Post)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [760, 640]
    },
    {
      "parameters": {
        "jsCode": "// Парсинг JSON ответа Gemini и фильтрация релизов\nconst results = [];\nfor (const item of $input.all()) {\n  try {\n    const text = item.json.candidates[0].content.parts[0].text.trim().replace(/```json|```/g, '');\n    const parsed = JSON.parse(text);\n    if (parsed.is_release && parsed.confidence >= 0.6 && parsed.artist && parsed.title) {\n      results.push({\n        json: {\n          artist: parsed.artist,\n          title: parsed.title,\n          release_type: parsed.release_type,\n          source: item.json._channel === 'cloudeluxe' ? 'ru_cloud' : 'us_rap',\n          url: item.json._link || null\n        }\n      });\n    }\n  } catch (e) {\n    // Пропуск в случае ошибки парсинга\n  }\n}\nreturn results;"
      },
