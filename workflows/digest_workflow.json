    {
      "parameters": {
        "url": "=https://ws.audioscrobbler.com/2.0/?method=artist.getsimilar&artist={{ encodeURIComponent($json.name) }}&api_key={{ $env.LASTFM_API_KEY }}&format=json&limit=5",
        "options": {}
      },
      "id": "4",
      "name": "Last.fm Similar Artists",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [540, 340]
    },
    {
      "parameters": {
        "jsCode": "// Слияние артистов из Spotify (followed, top) и Last.fm (similar)\nconst artistMap = new Map();\n\n// 1. Followed Artists\nconst followedItems = $items(\"Spotify Followed Artists\");\nfor (const item of followedItems) {\n  const artists = item.json.artists?.items || [];\n  for (const a of artists) {\n    artistMap.set(a.id, { id: a.id, name: a.name, source: 'followed', match_reason: 'Артист из ваших подписок' });\n  }\n}\n\n// 2. Top Artists\nconst topItems = $items(\"Spotify Top Artists\");\nfor (const item of topItems) {\n  const artists = item.json.items || [];\n  for (const a of artists) {\n    if (!artistMap.has(a.id)) {\n      artistMap.set(a.id, { id: a.id, name: a.name, source: 'top', match_reason: 'Ваш часто слушаемый артист' });\n    }\n  }\n}\n\n// 3. Similar Artists from Last.fm\nconst lastfmItems = $items(\"Last.fm Similar Artists\");\nfor (const item of lastfmItems) {\n  const similar = item.json.similarartists?.artist || [];\n  for (const a of similar) {\n    if (!Array.from(artistMap.values()).some(existing => existing.name.toLowerCase() === a.name.toLowerCase())) {\n      artistMap.set(`lastfm_${a.name}`, { id: null, name: a.name, source: 'similar', match_reason: `Похож на вашего любимого артиста` });\n    }\n  }\n}\n\nreturn Array.from(artistMap.values()).map(a => ({ json: a }));"
      },
      "id": "5",
      "name": "Code (Merge Artists)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [760, 260]
    },
    {
      "parameters": {
        "url": "=https://api.spotify.com/v1/artists/{{ $json.id }}/albums?include_groups=album,single&limit=10",
        "authentication": "genericCredentialType",
        "genericAuthType": "oAuth2Api",
        "options": {}
      },
      "id": "6",
      "name": "Spotify Get Artist Albums",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [980, 260],
      "credentials": {
        "oAuth2Api": {
          "id": "spotify_oauth",
          "name": "Spotify OAuth2"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Фильтр альбомов за последние 7 дней\nconst releases = [];\nconst now = new Date();\nconst sevenDaysAgo = new Date(now.getTime() - 7 * 24 * 60 * 60 * 1000);\n\nfor (const item of $input.all()) {\n  const albums = item.json.items || [];\n  const artistInfo = item.json._artistInfo || {};\n  for (const album of albums) {\n    const releaseDate = new Date(album.release_date);\n    if (releaseDate >= sevenDaysAgo) {\n      releases.push({\n        json: {\n          artist: album.artists.map(a => a.name).join(', '),\n          title: album.name,\n          release_type: album.album_type,\n          source: 'taste',\n          url: album.external_urls?.spotify || null,\n          release_date: album.release_date,\n          match_reason: 'Из ваших подписок / топа Spotify'\n        }\n      });\n    }\n  }\n}\nreturn releases;"
      },
      "id": "7",
      "name": "Code (Filter Taste 7 Days)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1200, 260]
