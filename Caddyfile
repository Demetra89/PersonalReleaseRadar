    # Маршрутизация RSSHub для Telegram каналов (например, /telegram/channel/cloudeluxe)
    handle /telegram/* {
        reverse_proxy rsshub:1200
    }

    # Основной веб-интерфейс и вебхуки n8n
    handle {
