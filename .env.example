# Доменное имя для Caddy и SSL (например, releaseradar.duckdns.org или IP)
DOMAIN_NAME=releaseradar.duckdns.org

# Настройки PostgreSQL
POSTGRES_USER=n8n
POSTGRES_PASSWORD=n8n_secure_password_change_me
POSTGRES_DB=n8n

# Секретный ключ шифрования n8n (сгенерируйте случайную строку)
N8N_ENCRYPTION_KEY=change_this_to_a_random_secret_string

# Spotify API Credential (Dev Mode)
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# Telegram Bot API
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Last.fm API Key
LASTFM_API_KEY=your_lastfm_api_key

# Gemini API Key (Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key
